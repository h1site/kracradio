# Supabase Configuration
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Application URL (for email verification redirects)
REACT_APP_URL=http://localhost:3000

# Brevo API Key (for newsletter subscription)
# Configure this in Supabase Edge Functions secrets
BREVO_API_KEY=your-brevo-api-key-here

# Optional: Google AdSense (production only)
# REACT_APP_ADSENSE_CLIENT=ca-pub-your-id-here

# PayPal Configuration (for donations)
# Get your client ID from: https://developer.paypal.com/dashboard/applications
# Use sandbox client ID for testing, live client ID for production
REACT_APP_PAYPAL_CLIENT_ID=your-paypal-client-id-here
