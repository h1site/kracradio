# SMTP Configuration for email sending
SMTP_HOST=h1site.com
SMTP_PORT=465
SMTP_USERNAME=noreply@kracradio.com
SMTP_PASSWORD=your-password-here
SMTP_FROM=KracRadio (Registration) <noreply@kracradio.com>

# Shopify Configuration (for store.kracradio.com integration)
# Get these from your Shopify Admin > Settings > Apps and sales channels > Develop apps
SHOPIFY_STORE_DOMAIN=store-kracradio.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret-here

# To set up Shopify webhooks, create the following webhooks in Shopify Admin:
# 1. orders/create -> https://your-supabase-url.functions.supabase.co/shopify-webhook
# 2. orders/paid -> https://your-supabase-url.functions.supabase.co/shopify-webhook
# 3. orders/cancelled -> https://your-supabase-url.functions.supabase.co/shopify-webhook
# 4. products/delete -> https://your-supabase-url.functions.supabase.co/shopify-webhook
